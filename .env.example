# Anthropic — diary synthesis LLM (required for POST /api/diary/entry and /reflect)
ANTHROPIC_API_KEY=sk-ant-...

# Circle — seller (server) nanopayments
SELLER_ADDRESS=0x...          # required — seller wallet for x402 middleware
CIRCLE_GATEWAY_URL=https://api.circle.com/v1/gateway   # optional facilitator URL
SELLER_PRIVATE_KEY=0x...      # NOT read by Next.js — Circle CLI / local wallet ops only

# Supabase (required for persistence)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Documentation only — not read by application code
CHAIN_NAME=arc-testnet

# Buyer wallet (agent scripts only — NOT server env)
# AGENT_WALLET_PRIVATE_KEY=0x...
